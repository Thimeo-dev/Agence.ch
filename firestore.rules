rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règles pour la collection utilisateurs
    match /utilisateurs/{userId} {
      // L'utilisateur peut lire et écrire seulement son propre document
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Règles pour d'autres collections si nécessaire
    match /{document=**} {
      allow read, write: if false; // Par défaut, rien n'est autorisé
    }
  }
}