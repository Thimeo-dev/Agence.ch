rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Règles pour les photos de profil
    match /profils/{userId} {
      // L'utilisateur peut lire et écrire seulement sa propre photo
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Règles pour d'autres fichiers si nécessaire
    match /{allPaths=**} {
      allow read, write: if false; // Par défaut, rien n'est autorisé
    }
  }
}